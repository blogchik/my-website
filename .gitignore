# Admin
admin/node_modules/
admin/.next/
admin/out/
admin/*.tsbuildinfo
admin/next-env.d.ts

# Yarn
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Env files
# .env.dev  → committed (safe dev defaults, no secrets)
# .env.prod → gitignored (real secrets, lives only on VPS)
.env
.env.*
!.env.example
!.env.dev

# Certbot / SSL (managed by Docker volumes, not tracked in git)
nginx/certbot/

# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Misc
*.pem
.vercel
__pycache__/
