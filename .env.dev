# ──────────────────────────────────────────────────────────
# .env.dev — Development environment variables
# Safe to commit. No secrets.
# ──────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────
NODE_ENV=development

# ── Next.js ────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1

# ── API ────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000

# ── Backend (FastAPI) ──────────────────────────────────────
DATABASE_URL=postgresql://dev:devpass@db:5432/mywebsite
RESEND_API_KEY=
CORS_ORIGIN=http://localhost:3000
API_DOMAIN=localhost
ENVIRONMENT=development
CONTACT_EMAIL_TO=blogchikuz@gmail.com
CONTACT_EMAIL_FROM=onboarding@resend.dev

# ── Admin / Auth (backend) ────────────────────────────────
ADMIN_CORS_ORIGIN=http://localhost:3001
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
ADMIN_GITHUB_ID=

# ── JWT ──────────────────────────────────────────────────
JWT_SECRET=dev-secret-key-not-for-production-use
JWT_ACCESS_EXPIRE_MINUTES=15
JWT_REFRESH_EXPIRE_DAYS=7

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=dev
POSTGRES_PASSWORD=devpass
POSTGRES_DB=mywebsite
