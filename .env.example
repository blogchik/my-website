# ──────────────────────────────────────────────────────────
# .env.example — Template for all environment variables
#
# For development: .env.dev is already committed with safe defaults
# For production:  create .env.prod on VPS and fill in real values
#
# Rule: all env vars live in root .env.dev / .env.prod only.
# Never create .env files inside frontend/, backend/, etc.
# Docker Compose passes them via env_file in docker-compose.*.yml
# ──────────────────────────────────────────────────────────

# ── App ────────────────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── Next.js ────────────────────────────────────────────────
NEXT_TELEMETRY_DISABLED=1

# ── SSL / Certbot (production only) ────────────────────────
DOMAIN=yourdomain.com
CERTBOT_EMAIL=you@yourdomain.com

# ── Frontend → Backend ─────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.yourdomain.com

# ── Backend (FastAPI) ──────────────────────────────────────
DATABASE_URL=postgresql://user:pass@db:5432/mydb
RESEND_API_KEY=re_xxxxxxxxxxxx
CORS_ORIGIN=https://yourdomain.com
API_DOMAIN=api.yourdomain.com
ENVIRONMENT=development
CONTACT_EMAIL_TO=you@yourdomain.com
CONTACT_EMAIL_FROM=onboarding@resend.dev

# ── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=user
POSTGRES_PASSWORD=change_me_to_a_secure_password
POSTGRES_DB=mydb
